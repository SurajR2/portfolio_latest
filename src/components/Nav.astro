---
interface NavLink {
    href: string;
    label: string;
}

const links: readonly NavLink[] = [
    { href: "/work", label: "~/work" },
    { href: "/blogs", label: "~/blogs" },
    { href: "/stack", label: "~/stack" },
    { href: "/contact", label: "~/contact" },
] as const;

const mobileLinks: readonly NavLink[] = [
    { href: "/", label: "~/home" },
    ...links,
] as const;

const pathname: string = Astro.url.pathname;

const isActive = (href: string): boolean => {
    if (href === "/") return pathname === "/";
    return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header
    class="sticky top-0 z-40 backdrop-blur-md bg-base/80 border-b border-line [-webkit-backdrop-filter:saturate(140%)_blur(10px)] [backdrop-filter:saturate(140%)_blur(10px)]"
    data-nav
    transition:persist="nav-header"
>
    <div class="container-page flex items-center justify-between py-4">
        <a
            class="inline-flex items-baseline font-mono text-sm font-semibold text-fg"
            href="/"
            aria-label="suraj — home"
        >
            <span class="text-accent">~/</span><span class="text-fg">suraj</span
            >
            <span
                class="inline-block w-[0.55em] h-[1.1em] bg-accent ml-[0.2em] translate-y-[0.12em] motion-safe:animate-[nav-blink_1s_steps(2)_infinite]"
                aria-hidden="true"></span>
        </a>

        <nav
            class="hidden sm:inline-flex items-center gap-6"
            aria-label="primary"
        >
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class:list={[
                            "inline-flex items-center min-h-[44px] px-1.5 py-1 font-mono text-xs tracking-wide border-t border-transparent transition-colors duration-150",
                            isActive(link.href)
                                ? "text-accent !border-accent"
                                : "text-muted hover:text-accent",
                        ]}
                        aria-current={isActive(link.href) ? "page" : undefined}
                    >
                        {link.label}
                    </a>
                ))
            }
        </nav>

        <button
            type="button"
            class="sm:hidden inline-flex flex-col items-center justify-center w-11 h-11 gap-[5px] border border-line-strong rounded-sm bg-transparent cursor-pointer transition-colors duration-150 hover:border-accent"
            aria-label="open menu"
            aria-expanded="false"
            aria-controls="mobile-sheet"
            data-toggle
        >
            <span class="block w-4 h-px bg-fg"></span>
            <span class="block w-4 h-px bg-fg"></span>
        </button>
    </div>
</header>

<!--
  Mobile dropdown — compact panel anchored under the nav bar. Lives
  outside <header> so its `position: fixed` is rooted to the viewport
  (the header has backdrop-filter, which would otherwise make it the
  containing block for fixed descendants).
-->
<div
    id="mobile-sheet"
    class="sheet fixed top-[60px] right-3 z-50 w-[220px] max-w-[calc(100vw-24px)] origin-top-right bg-base-2 border border-line-strong rounded shadow-lg shadow-black/40 opacity-0 scale-95 pointer-events-none transition-[opacity,transform] duration-150 ease-out data-[open=true]:opacity-100 data-[open=true]:scale-100 data-[open=true]:pointer-events-auto"
    role="menu"
    aria-label="navigation"
    data-sheet
    hidden
    transition:persist="nav-sheet"
>
    <nav class="flex flex-col py-1.5" aria-label="mobile">
        {
            mobileLinks.map((link) => (
                <a
                    href={link.href}
                    role="menuitem"
                    class:list={[
                        "sheet-link font-mono text-[13px] leading-none px-3.5 py-2.5 transition-colors duration-150 hover:bg-base-3 hover:text-accent",
                        isActive(link.href) ? "text-accent" : "text-muted",
                    ]}
                    aria-current={isActive(link.href) ? "page" : undefined}
                >
                    {link.label}
                </a>
            ))
        }
    </nav>
</div>

<style>
    /* Cursor blink keyframes — Tailwind cannot express keyframes in utilities. */
    @keyframes nav-blink {
        50% {
            opacity: 0;
        }
    }

    /* Hide the dropdown when [hidden] is set, and force it off on desktop
     regardless of [data-open] state. */
    .sheet[hidden] {
        display: none !important;
    }
    @media (min-width: 641px) {
        .sheet {
            display: none !important;
        }
    }
</style>

<script>
    type Nullable<T> = T | null;

    // The nav element is `transition:persist`-ed across navigations, so its
    // event listeners survive view transitions. Re-running init on every
    // page-load would otherwise attach duplicate handlers (toggle gets
    // two click listeners → first opens the sheet, second immediately
    // closes it).
    let navBootstrapped = false;

    const init = (): void => {
        if (navBootstrapped) return;
        const toggle =
            document.querySelector<HTMLButtonElement>("[data-toggle]");
        const sheet = document.querySelector<HTMLElement>("[data-sheet]");
        if (!toggle || !sheet) return;
        navBootstrapped = true;

        const setOpen = (open: boolean): void => {
            sheet.dataset.open = String(open);
            toggle.setAttribute("aria-expanded", String(open));
            if (open) {
                sheet.removeAttribute("hidden");
            } else {
                // Defer hidden so the slide-out transition can play
                window.setTimeout((): void => {
                    if (sheet.dataset.open !== "true")
                        sheet.setAttribute("hidden", "");
                }, 160);
            }
        };

        toggle.addEventListener("click", (event: MouseEvent): void => {
            event.stopPropagation();
            const open: boolean = sheet.dataset.open !== "true";
            setOpen(open);
        });

        sheet
            .querySelectorAll<HTMLAnchorElement>("a.sheet-link")
            .forEach((link: HTMLAnchorElement): void => {
                link.addEventListener("click", (): void => setOpen(false));
            });

        // Click-outside to dismiss
        document.addEventListener("click", (event: MouseEvent): void => {
            if (sheet.dataset.open !== "true") return;
            const target = event.target as Node | null;
            if (!target) return;
            if (!sheet.contains(target) && !toggle.contains(target)) {
                setOpen(false);
            }
        });

        document.addEventListener("keydown", (event: KeyboardEvent): void => {
            if (event.key === "Escape" && sheet.dataset.open === "true") {
                setOpen(false);
                toggle.focus();
            }
        });
    };

    // Refresh active-link state for the persisted nav. With
    // `transition:persist`, the SSR-rendered active classes from the
    // first-loaded page would otherwise stay frozen.
    const isActive = (href: string, pathname: string): boolean => {
        if (href === "/") return pathname === "/";
        return pathname === href || pathname.startsWith(`${href}/`);
    };

    const ACTIVE_CLASSES: readonly string[] = ["text-accent", "!border-accent"];
    const INACTIVE_CLASSES: readonly string[] = [
        "text-muted",
        "hover:text-accent",
    ];

    const syncActive = (): void => {
        const path: string = window.location.pathname;
        document
            .querySelectorAll<HTMLAnchorElement>("header[data-nav] nav a[href]")
            .forEach((a: HTMLAnchorElement): void => {
                const href: string | null = a.getAttribute("href");
                if (!href) return;
                const active: boolean = isActive(href, path);
                if (active) {
                    a.classList.add(...ACTIVE_CLASSES);
                    a.classList.remove(...INACTIVE_CLASSES);
                    a.setAttribute("aria-current", "page");
                } else {
                    a.classList.remove(...ACTIVE_CLASSES);
                    a.classList.add(...INACTIVE_CLASSES);
                    a.removeAttribute("aria-current");
                }
            });

        // Sheet links carry their own simpler active style.
        document
            .querySelectorAll<HTMLAnchorElement>("[data-sheet] a.sheet-link")
            .forEach((a: HTMLAnchorElement): void => {
                const href: string | null = a.getAttribute("href");
                if (!href) return;
                const active: boolean = isActive(href, path);
                a.classList.toggle("text-accent", active);
                a.classList.toggle("text-fg", !active);
                if (active) a.setAttribute("aria-current", "page");
                else a.removeAttribute("aria-current");
            });
    };

    // Run on first load and on Astro view transitions
    document.addEventListener("astro:page-load", (): void => {
        init();
        syncActive();
    });
    if (document.readyState !== "loading") {
        init();
        syncActive();
    } else {
        document.addEventListener("DOMContentLoaded", (): void => {
            init();
            syncActive();
        });
    }

    // Reset overflow on navigation
    document.addEventListener("astro:before-swap", (): void => {
        document.body.style.overflow = "";
        const sheet: Nullable<HTMLElement> =
            document.querySelector("[data-sheet]");
        if (sheet) {
            sheet.dataset.open = "false";
            sheet.setAttribute("hidden", "");
        }
    });
</script>
