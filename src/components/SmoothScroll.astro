---
// SmoothScroll.astro
// Lenis-based smooth scrolling. Honors prefers-reduced-motion (falls back
// to native scroll). Re-initializes across Astro View Transitions.
---

<script>
  import Lenis from 'lenis';
  import 'lenis/dist/lenis.css';

  type LenisInstance = InstanceType<typeof Lenis>;

  // Module-scoped state survives across the IIFE invocation; Astro bundles
  // this script once per page load.
  let lenis: LenisInstance | null = null;
  let rafId: number | null = null;
  let anchorHandler: ((event: MouseEvent) => void) | null = null;
  let lifecycleAttached = false;

  const NAV_OFFSET = -72;

  const prefersReducedMotion = (): boolean => {
    if (typeof window === 'undefined' || typeof window.matchMedia !== 'function') {
      return false;
    }
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  };

  const onAnchorClick = (event: MouseEvent): void => {
    if (!lenis) return;
    const target = event.target;
    if (!(target instanceof Element)) return;

    const anchor = target.closest('a[href^="#"]');
    if (!(anchor instanceof HTMLAnchorElement)) return;

    const href = anchor.getAttribute('href');
    if (!href || href === '#') return;

    // Allow modified clicks to behave natively (open in new tab, etc.).
    if (event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
      return;
    }

    const id = href.slice(1);
    const destination = document.getElementById(id);
    if (!destination) return;

    event.preventDefault();
    lenis.scrollTo(destination, { offset: NAV_OFFSET });
  };

  const startRaf = (instance: LenisInstance): void => {
    const tick = (time: number): void => {
      instance.raf(time);
      rafId = window.requestAnimationFrame(tick);
    };
    rafId = window.requestAnimationFrame(tick);
  };

  const initLenis = (): void => {
    if (typeof window === 'undefined' || typeof document === 'undefined') return;
    if (lenis) return;
    if (prefersReducedMotion()) return;

    lenis = new Lenis({
      duration: 1.1,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
      wheelMultiplier: 1.0,
      touchMultiplier: 1.4,
      lerp: 0.1,
      syncTouch: false,
    });

    document.documentElement.classList.add('lenis-active');

    startRaf(lenis);

    anchorHandler = onAnchorClick;
    document.addEventListener('click', anchorHandler);
  };

  const destroyLenis = (): void => {
    if (rafId !== null) {
      window.cancelAnimationFrame(rafId);
      rafId = null;
    }
    if (anchorHandler) {
      document.removeEventListener('click', anchorHandler);
      anchorHandler = null;
    }
    if (lenis) {
      lenis.destroy();
      lenis = null;
    }
    document.documentElement.classList.remove('lenis-active');
  };

  const attachLifecycle = (): void => {
    if (lifecycleAttached) {
      // Re-initialize for the current page if the script ran a second time.
      destroyLenis();
      initLenis();
      return;
    }
    lifecycleAttached = true;

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLenis, { once: true });
    } else {
      initLenis();
    }

    document.addEventListener('astro:page-load', () => {
      destroyLenis();
      initLenis();
    });
    document.addEventListener('astro:before-swap', destroyLenis);
  };

  attachLifecycle();
</script>
