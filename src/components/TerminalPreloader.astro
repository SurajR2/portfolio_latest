---
/**
 * TerminalPreloader.astro
 *
 * Boot-sequence preloader. Shows once per session on first page load,
 * then fades out and unmounts. Skipped on subsequent navigations
 * (sessionStorage flag) and on prefers-reduced-motion.
 *
 * - ESC or skip button dismisses immediately.
 * - Total timeline ≈ 1700ms + 360ms fade = 2060ms.
 * - Body scroll is locked while booting.
 * - Animations use opacity + transform only (no layout reflow).
 */
---

<div id="boot-preloader" class="boot-preloader" role="status" aria-live="polite" aria-label="loading interface" data-boot>
  <div class="boot-window">
    <div class="boot-line" style="--i: 0">
      <span class="boot-prompt">$</span> ./suraj --boot
    </div>
    <div class="boot-line" style="--i: 1">
      <span class="boot-status">[ ok ]</span> loading core modules
    </div>
    <div class="boot-line" style="--i: 2">
      <span class="boot-status">[ ok ]</span> mounting filesystem
    </div>
    <div class="boot-line" style="--i: 3">
      <span class="boot-status">[ ok ]</span> initializing runtime
    </div>
    <div class="boot-line" style="--i: 4">
      <span class="boot-status">[ ok ]</span> resolving routes
    </div>
    <div class="boot-line" style="--i: 5">
      <span class="boot-status">[ ok ]</span> starting interface
    </div>

    <div class="boot-progress" style="--i: 6" aria-hidden="true">
      <div class="boot-progress-bar"><div class="boot-progress-fill"></div></div>
      <span class="boot-progress-pct">100%</span>
    </div>

    <div class="boot-line boot-ready" style="--i: 7">
      <span class="boot-prompt">$</span> ready<span class="boot-cursor" aria-hidden="true"></span>
    </div>
  </div>

  <button type="button" class="boot-skip" data-boot-skip aria-label="skip intro">
    skip <span aria-hidden="true">→</span>
  </button>
</div>

<style>
  .boot-preloader {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-base);
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 1;
    transition: opacity 360ms cubic-bezier(0.2, 0, 0.1, 1);
  }

  .boot-preloader[data-done="true"] {
    opacity: 0;
    pointer-events: none;
  }

  .boot-window {
    width: min(560px, calc(100vw - 48px));
    padding: 24px 28px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-base-2);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.85;
    color: var(--color-fg);
  }

  .boot-line {
    opacity: 0;
    transform: translateY(4px);
    animation: boot-fade-in 220ms cubic-bezier(0.2, 0, 0.1, 1) forwards;
    animation-delay: calc(var(--i) * 140ms);
  }

  .boot-prompt {
    color: var(--color-accent);
    font-weight: 600;
    margin-right: 4px;
  }
  .boot-status {
    color: var(--color-success);
    margin-right: 8px;
  }

  .boot-progress {
    margin-top: 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    animation: boot-fade-in 220ms cubic-bezier(0.2, 0, 0.1, 1) forwards;
    animation-delay: calc(var(--i) * 140ms);
  }
  .boot-progress-bar {
    flex: 1;
    height: 6px;
    background: var(--color-base-3);
    border: 1px solid var(--color-line-strong);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .boot-progress-fill {
    height: 100%;
    background: var(--color-accent);
    transform-origin: left;
    transform: scaleX(0);
    animation: boot-progress 700ms cubic-bezier(0.2, 0, 0.1, 1) forwards;
    animation-delay: calc(var(--i) * 140ms + 120ms);
  }
  .boot-progress-pct {
    color: var(--color-muted);
    font-size: 11px;
    min-width: 36px;
    text-align: right;
    letter-spacing: 0.04em;
  }

  .boot-ready {
    margin-top: 12px;
    color: var(--color-fg);
  }
  .boot-cursor {
    display: inline-block;
    width: 0.55em;
    height: 1.1em;
    background: var(--color-accent);
    vertical-align: -0.18em;
    margin-left: 0.25em;
    animation: boot-cursor-blink 1s steps(2) infinite;
  }

  .boot-skip {
    position: absolute;
    top: 24px;
    right: 24px;
    min-height: 44px;
    padding: 8px 14px;
    border: 1px solid var(--color-line-strong);
    border-radius: var(--radius-sm);
    background: transparent;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    cursor: pointer;
    transition: color 150ms cubic-bezier(0.2, 0, 0.1, 1),
      border-color 150ms cubic-bezier(0.2, 0, 0.1, 1);
  }
  .boot-skip:hover,
  .boot-skip:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
    outline: none;
  }

  @keyframes boot-fade-in {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes boot-progress {
    to { transform: scaleX(1); }
  }
  @keyframes boot-cursor-blink {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .boot-preloader {
      display: none;
    }
  }
</style>

<script>
  const FLAG = 'suraj.boot.shown';
  const TIMELINE_MS = 1700;
  const FADE_MS = 360;

  type Nullable<T> = T | null;

  const dismiss = (overlay: HTMLElement, immediate = false): void => {
    if (immediate) {
      overlay.style.transition = 'none';
    }
    overlay.dataset.done = 'true';
    document.body.style.overflow = '';
    // Mark the session as having seen the boot. From this point on, any
    // navigation or refresh will skip the preloader.
    sessionStorage.setItem(FLAG, '1');
    window.setTimeout(
      (): void => {
        overlay.remove();
        // Only mark the document AFTER the overlay is gone — the global CSS
        // gate (html.boot-seen .boot-preloader { display:none }) would
        // otherwise fire mid-animation and hide the still-running preloader.
        document.documentElement.classList.add('boot-seen');
      },
      immediate ? 0 : FADE_MS,
    );
  };

  const init = (): void => {
    const overlay: Nullable<HTMLElement> = document.querySelector<HTMLElement>(
      '[data-boot]',
    );
    if (!overlay) return;

    // Skip if already shown this session, or if user prefers reduced motion
    const reduceMotion: boolean = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;
    const seen: boolean = sessionStorage.getItem(FLAG) === '1';

    if (seen || reduceMotion) {
      overlay.remove();
      document.documentElement.classList.add('boot-seen');
      return;
    }

    document.body.style.overflow = 'hidden';

    const timer: number = window.setTimeout(
      (): void => dismiss(overlay),
      TIMELINE_MS,
    );

    const skip = (): void => {
      window.clearTimeout(timer);
      dismiss(overlay);
    };

    overlay
      .querySelector<HTMLButtonElement>('[data-boot-skip]')
      ?.addEventListener('click', skip);

    document.addEventListener('keydown', (event: KeyboardEvent): void => {
      if (event.key === 'Escape') skip();
    });
  };

  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);

  // ClientRouter merges <html> attributes from the incoming page on every
  // navigation, which strips our `boot-seen` class. Re-add it to the new
  // document BEFORE the swap so the CSS gate (html.boot-seen .boot-preloader
  // { display:none }) is in place by the time the new body paints.
  document.addEventListener('astro:before-swap', (event: Event): void => {
    if (sessionStorage.getItem(FLAG) !== '1') return;
    const swap = event as Event & { newDocument?: Document };
    if (swap.newDocument) {
      swap.newDocument.documentElement.classList.add('boot-seen');
    }
  });

  // Belt-and-suspenders: after every navigation completes, re-mark the
  // current document and remove any leftover preloader markup.
  document.addEventListener('astro:page-load', (): void => {
    if (sessionStorage.getItem(FLAG) === '1') {
      document.documentElement.classList.add('boot-seen');
      document
        .querySelector<HTMLElement>('[data-boot]')
        ?.remove();
    }
  });
</script>
