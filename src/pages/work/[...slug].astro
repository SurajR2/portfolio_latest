---
/**
 * /work/[...slug] — single work entry.
 *
 * Renders the MDX body of a `work` collection entry along with framing
 * metadata (role, year, stack, metrics) and prev/next navigation by year.
 */

import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';

type WorkEntry = CollectionEntry<'work'>;

interface PathProps {
  entry: WorkEntry;
  prev: WorkEntry | null;
  next: WorkEntry | null;
}

export async function getStaticPaths() {
  const entries: WorkEntry[] = await getCollection(
    'work',
    ({ data }) => !data.draft,
  );

  const sorted: WorkEntry[] = [...entries].sort(
    (a: WorkEntry, b: WorkEntry): number => b.data.year - a.data.year,
  );

  return sorted.map((entry: WorkEntry, i: number) => {
    const prev: WorkEntry | null = i > 0 ? sorted[i - 1] : null;
    const next: WorkEntry | null = i < sorted.length - 1 ? sorted[i + 1] : null;
    return {
      params: { slug: entry.id.replace(/\.(mdx?)$/, '') },
      props: { entry, prev, next } satisfies PathProps,
    };
  });
}

type Props = PathProps;

const { entry, prev, next } = Astro.props as Props;
const { Content } = await render(entry);

const role: string = entry.data.role ?? 'engineer';
const stack: readonly string[] = entry.data.stack;
const metrics: readonly string[] | undefined = entry.data.metrics;
const homepage: string | undefined = entry.data.homepage;
const homepageHost: string | undefined = homepage
  ? new URL(homepage).host.replace(/^www\./, '')
  : undefined;

const pageTitle = `${entry.data.title} — ~/work`;
const pageDescription: string = entry.data.summary;
---

<Layout title={pageTitle} description={pageDescription}>
  <article class="container-page pt-12 pb-24">
      <Reveal as="div" delay={0} y={8}>
        <a href="/work/" class="font-mono text-xs text-muted hover:text-accent transition-colors inline-block mb-6">← ~/work</a>
      </Reveal>

      <Reveal as="header" delay={60} y={16} class="mb-8">
        <div class="font-mono text-[11px] uppercase tracking-widest text-faint mb-3">// {entry.data.year} · {role}</div>
        <h1 class="font-mono text-[clamp(26px,4vw,40px)] font-bold tracking-tight leading-[1.2] mb-5">{entry.data.title}</h1>
        <p class="font-mono text-base text-muted leading-relaxed mb-12">{entry.data.summary}</p>
      </Reveal>

      <Reveal as="section" delay={140} y={20} class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16 border-y border-line py-8" aria-label="entry metadata">
      <div class="flex flex-col gap-2">
        <dt class="font-mono text-[11px] uppercase tracking-widest text-faint">stack</dt>
        <dd class="flex flex-wrap gap-1.5">
          <ul class="flex flex-wrap gap-1.5" role="list">
            {stack.map((tag: string) => (
              <li class="font-mono text-[11px] px-2 py-0.5 border border-line-strong rounded-sm text-fg">{tag}</li>
            ))}
          </ul>
        </dd>
      </div>

      <div class="flex flex-col gap-2">
        <dt class="font-mono text-[11px] uppercase tracking-widest text-faint">year</dt>
        <dd class="font-mono text-fg text-base">{entry.data.year}</dd>
      </div>

      {homepage ? (
        <div class="flex flex-col gap-2">
          <dt class="font-mono text-[11px] uppercase tracking-widest text-faint">homepage</dt>
          <dd>
            <a
              href={homepage}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-sm text-fg border-b border-dotted border-line-strong hover:text-accent hover:border-accent transition-colors inline-flex items-center gap-1.5"
            >
              {homepageHost} <span aria-hidden="true">↗</span>
            </a>
          </dd>
        </div>
      ) : null}

      {metrics && metrics.length > 0 ? (
        <div class="flex flex-col gap-2">
          <dt class="font-mono text-[11px] uppercase tracking-widest text-faint">metrics</dt>
          <dd>
            <ul class="font-mono text-xs text-muted leading-relaxed flex flex-col gap-1" role="list">
              {metrics.map((m: string) => (
                <li>— {m}</li>
              ))}
            </ul>
          </dd>
        </div>
      ) : null}
    </Reveal>

      <Reveal as="div" delay={200} y={20}>
        <article class="prose">
          <Content />
        </article>
      </Reveal>

      <Reveal as="nav" delay={260} y={16} class="flex items-center justify-between gap-4 mt-16 pt-8 border-t border-line font-mono text-xs" aria-label="adjacent entries">
        <div class="min-w-0">
          {prev ? (
            <a href={`/work/${prev.id.replace(/\.(mdx?)$/, '')}/`} class="text-muted hover:text-accent transition-colors inline-flex flex-col gap-1">
              <span class="text-[11px] uppercase tracking-widest text-faint">← prev</span>
              <span class="text-fg">{prev.data.title}</span>
            </a>
          ) : (
            <span class="text-faint">// start of log</span>
          )}
        </div>
        <div class="min-w-0 text-right">
          {next ? (
            <a href={`/work/${next.id.replace(/\.(mdx?)$/, '')}/`} class="text-muted hover:text-accent transition-colors inline-flex flex-col gap-1">
              <span class="text-[11px] uppercase tracking-widest text-faint">next →</span>
              <span class="text-fg">{next.data.title}</span>
            </a>
          ) : (
            <span class="text-faint">// end of log</span>
          )}
        </div>
      </Reveal>
  </article>
</Layout>

<style>
  /* Divergent prose rules: mono headings with `// ` prefix.
     Other long-form prose styling lives in global `.prose`. */
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: var(--font-mono);
  }
  .prose :global(h2)::before,
  .prose :global(h3)::before,
  .prose :global(h4)::before {
    content: '// ';
    color: var(--color-accent);
  }
</style>
